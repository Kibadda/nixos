#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SELF_DIR/.." && pwd)"

SERVICE_FILES=$(git diff --cached --name-only --diff-filter=ACMR |
  grep -cE '^modules/services/|^modules/hosts/oberon\.nix$' || true)

if [ "$SERVICE_FILES" -gt 0 ]; then
  "$REPO/scripts/generate-oberon-services.sh"
  git add "$REPO/docs/services.md"
fi
